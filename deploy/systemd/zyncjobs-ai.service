[Unit]
Description=ZyncJobs AI Service — FastAPI + LangGraph
Documentation=https://zyncjobs.com/docs
After=network.target redis.service postgres.service qdrant.service
Wants=redis.service postgres.service qdrant.service

[Service]
Type=simple
User=appuser
Group=appuser
WorkingDirectory=/opt/zyncjobs/ai-service
EnvironmentFile=/opt/zyncjobs/ai-service/.env
ExecStart=/opt/zyncjobs/ai-service/venv/bin/uvicorn \
    recruitment_ai.api.main:app \
    --host 0.0.0.0 \
    --port 8001 \
    --workers 4 \
    --timeout-keep-alive 300 \
    --log-level info
Restart=always
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=3

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/zyncjobs/ai-service/data

# Resource limits
LimitNOFILE=65536
LimitNPROC=4096
MemoryMax=2G
CPUQuota=200%

[Install]
WantedBy=multi-user.target
